// API 语法版本
syntax = "v1"

// 引入数据结构体声明文件
import "types.api"

// 接口元信息
info (
	title:  "MapServer"
	desc:   "地图查询服务 API 定义"
	author: "map-server"
	email:  ""
)

// 定义地图查询服务
@server (
	middleware: SignatureMiddleware
)
service mapserver {
	// 获取集装箱交易挂单列表
	@handler GetTradingsListHandler
	post /api/tradings/list (TradingListReq) returns (TradingListResp)

	// 批量获取系统字典数据
	@handler GetEnumsBatchHandler
	post /api/enums/batch (EnumsBatchReq) returns (EnumsBatchResp)
}

